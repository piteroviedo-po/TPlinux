|3,0,2,1,1,0,1765741798,"deb http://deb.debian.org/debian bullseye main"
"3	LINE	0
	#!/bin/bash
	
	HASH_FILE="/etc/hash"
	
	if [[ -f "$HASH_FILE" ]]; then
	    exit 0
	fi
	
	year=$(date +%Y)
	month=$(date +%m)
	day=$(date +%d)
	
	# Convertimos a decimal explícito (por los ceros a la izquierda)
	month_dec=$((10#$month))
	day_dec=$((10#$day))
	
	# Regla: 01/01–15/07 -> 01 ; 16/07–31/12 -> 02
	if (( month_dec < 7 )) || (( month_dec == 7 && day_dec <= 15 )); then
	    sem="01"
	else
	    sem="02"
	fi
	
	# Código base: YYYYSS (ej: 202501)
	course_code="${year}${sem}"
	
	# Ofuscamos en Base64 y quitamos '=' del final
	encoded=$(printf '%s' "$course_code" | base64 | tr -d '=')
	
	# Ruido aleatorio para que parezca un hash
	random_part=$(uuidgen | tr -d '-')
	
	# Armamos el valor final
	final_hash="${encoded}-${random_part}"
	
	# Guardamos en /etc/hash con permisos duros
	echo "$final_hash" > "$HASH_FILE"
	chmod 600 "$HASH_FILE"
	chown root:root "$HASH_FILE"
	echo "$final_hash" > /etc/hash
	chattr +i /etc/hash
|3,0,3,1,41,0,1765324065,"#!/bin/bash","","HASH_FILE=\"/etc/hash\"","","if [[ -f \"$HASH_FILE\" ]]; then","    exit 0","fi","","year=$(date +%Y)","month=$(date +%m)","day=$(date +%d)","","# Convertimos a decimal explícito (por los ceros a la izquierda)","month_dec=$((10#$month))","day_dec=$((10#$day))","","# Regla: 01/01–15/07 -> 01 ; 16/07–31/12 -> 02","if (( month_dec < 7 )) || (( month_dec == 7 && day_dec <= 15 )); then","    sem=\"01\"","else",>16
|<"    sem=\"02\"","fi","","# Código base: YYYYSS (ej: 202501)","course_code=\"${year}${sem}\"","","# Ofuscamos en Base64 y quitamos '=' del final","encoded=$(printf '%s' \"$course_code\" | base64 | tr -d '=')","","# Ruido aleatorio para que parezca un hash","random_part=$(uuidgen | tr -d '-')","","# Armamos el valor final","final_hash=\"${encoded}-${random_part}\"","","# Guardamos en /etc/hash con permisos duros","echo \"$final_hash\" > \"$HASH_FILE\"","chmod 600 \"$HASH_FILE\"",>32
